@wire(local-shell-cmd-inner {
  Once({
    false >= retrying-connection
  })
  
  = input-table
  
  // Check if session needs (re)creation
  When({
      Get(g/globals "local-shell/session" Global: true Default: {}) | Is({}) | Or
      Get(g/globals "local-shell/shell" Global: true Default: "") | IsNot((env.local-shell-bin | If(IsNone {""} ExpectString))) | Or
      Get(g/globals "local-shell/working-dir" Global: true Default: "") | IsNot((env.local-shell-working-dir | If(IsNone {""} ExpectString)))
    } {
      Msg("Creating local shell session")
      
      env.local-shell-bin | If(IsNone {""} ExpectString) | Set(g/globals "local-shell/shell" Global: true) | Log("Local shell binary") = shell-bin
      env.local-shell-working-dir | If(IsNone {""} ExpectString) | Set(g/globals "local-shell/working-dir" Global: true) | Log("Working directory") = shell-working-dir
      
      {
        session: (
        shell-bin | If(IsNot("") {
              shell-working-dir | If(IsNot("") {
                  LocalShell.Create(Shell: shell-bin WorkingDirectory: shell-working-dir Rows: 40 Cols: 120)
                } {
                  LocalShell.Create(Shell: shell-bin Rows: 40 Cols: 120)
                }
              )
            } {
              shell-working-dir | If(IsNot("") {
                  LocalShell.Create(WorkingDirectory: shell-working-dir Rows: 40 Cols: 120)
                } {
                  LocalShell.Create(Rows: 40 Cols: 120)
                }
              )
            }
          )
        )
      } | ToAnyTable | Set(g/globals "local-shell/session" Global: true)
    }
  )
  
  Get(g/globals "local-shell/session" Global: true Default: {}) | Take("session")
  Expect(@type(Type::Object ObjectName: "LocalShell.Session")) >= local-shell-session
  WhenNot(LocalShell.IsAlive {
    If({retrying-connection | Not} {
        {} | Set(g/globals "local-shell/session" Global: true)
        true > retrying-connection
        input-table | Restart
      } {
        "Local shell session failed. The shell process may have exited unexpectedly." | Fail
      }
    )
  })
  
  // Determine mode: raw_mode=1 for TUI/raw interaction, default for execute mode
  input-table.raw_mode | If(IsInt ExpectInt {0}) >= raw-mode
  
  // Handle resize if requested
  input-table.rows | If(IsInt ExpectInt {0}) >= req-rows
  input-table.cols | If(IsInt ExpectInt {0}) >= req-cols
  When({req-rows | IsMore(0) | And | req-cols | IsMore(0)} {
    LocalShell.Resize(Session: local-shell-session Rows: req-rows Cols: req-cols)
  })
  
  raw-mode | If(IsMore(0) {
      // === Raw mode: TUI/interactive applications ===
      input-table.input_str | If(IsNone {
          // No input_str — check for cmd to start a new program, or just read
          input-table.cmd | If(IsNone {
              // Neither cmd nor input_str — just read current output
              ""
            } {
              ExpectString
            }
          )
        } {
          ExpectString
        }
      ) = raw-input
      
      // Write input if non-empty
      raw-input | When(IsNot("") {
        LocalShell.Write(Session: local-shell-session AppendNewline: false)
      })
      
      // Read output with timeout (500ms default for meaningful TUI responses)
      input-table.timeout_ms | If(IsInt ExpectInt {500}) >= read-timeout
      LocalShell.Read(Session: local-shell-session StripAnsi: true Timeout: read-timeout) = raw-output
      
      {
        status: "raw"
        output: raw-output
      }
    } {
      // === Execute mode: standard command execution ===
      Maybe({
          input-table.input_str | If(IsNone {
              // New command execution
              input-table.cmd | ExpectString | LocalShell.Execute(Session: local-shell-session MaxOutputBytes: 32768)
            } {
              // Interactive input
              ExpectString | LocalShell.SendInput(Session: local-shell-session MaxOutputBytes: 32768)
            }
          ) | ToAnyTable
        } {
          If({retrying-connection | Not} {
              {} | Set(g/globals "local-shell/session" Global: true)
              true > retrying-connection
              input-table | Restart
            } {
              "Local shell command execution failed. The shell process may have exited unexpectedly." | Fail
            }
          )
        }
      )
      {
        status: (Take("status") | ExpectString)
        output: (Take("output") | ExpectString)
      }
    }
  )
})

@define(supported-platform #(@platform | IsAny(["macos"])))

@wire(local-shell-cmd {
  ExpectTable | ToAnyTable
  @if(@supported-platform {
      Do(local-shell-cmd-inner)
    } {
      "Unsupported platform to send local shell commands" | Fail
    }
  )
})

{
  definition: {
    name: "local_shell_cmd"
    description: """* Execute shell commands or interact with TUI applications in a persistent local shell session.
* Preserves state, environment variables, and working directory between calls.

## Execute mode (default):
* Send a command with 'cmd' — returns when command completes or needs input.
* If status is 'requires_interaction', use 'input_str' (omit 'cmd') to send input.
* Send a new 'cmd' to cancel a waiting interactive command and start fresh.

## Raw mode (set raw_mode=1):
* For TUI/interactive programs like top, htop, vim, claude, etc.
* Send 'cmd' to start a program, 'input_str' to send keystrokes, or omit both to read current output.
* Output is stripped of ANSI codes. Use 'timeout_ms' to control read wait time.
* Use 'rows' and 'cols' to resize the terminal.

## Environment variables (Settings -> Customizations -> Environment variables):
* local-shell-bin: Shell binary path (default: /bin/bash)
* local-shell-working-dir: Initial working directory

## Notes:
TUI apps (like `claude`, `vim`, `htop`) may take a moment to render their first frame after launch. If the first read returns empty, send a follow-up read (or a harmless keypress like `\r`) with the same `timeout_ms` to capture the rendered output. This is normal — the app is still initializing."""
    parameters: {
      type: "object"
      properties: {
        cmd: {
          type: "string"
          description: "Shell command to execute (execute mode) or TUI program to start (raw mode)."
        }
        input_str: {
          type: "string"
          description: "Input to send to a waiting command. In raw mode, this sends keystrokes to the TUI application."
        }
        raw_mode: {
          type: "integer"
          description: "Set to 1 for raw/TUI mode. Default 0 (execute mode). Use raw mode for interactive programs like top, vim, claude."
        }
        timeout_ms: {
          type: "integer"
          description: "Read timeout in milliseconds for raw mode (default: 500). Increase for slow-starting programs."
        }
        rows: {
          type: "integer"
          description: "Resize terminal to this many rows. Must specify both rows and cols."
        }
        cols: {
          type: "integer"
          description: "Resize terminal to this many columns. Must specify both rows and cols."
        }
      }
      required: []
    }
  }
  
  use: local-shell-cmd
}


